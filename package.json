{
  "name": "hramgo",
  "version": "0.1.0",
  "private": true,
  "description": "HramGo: mobile-first православный помощник для поиска храмов РПЦ Москвы.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "import:official-list": "tsx scripts/import-official-list.ts",
    "discover:websites": "tsx scripts/discover-websites.ts",
    "crawl:temple": "tsx scripts/crawl-temple.ts",
    "extract:llm": "tsx scripts/extract-llm.ts",
    "geocode:temples": "tsx scripts/geocode-temples.ts",
    "moderation:queue": "tsx scripts/moderation-queue.ts",
    "recalculate:ratings": "tsx scripts/recalculate-ratings.ts",
