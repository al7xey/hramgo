    "framer-motion": "^12.23.24",
    "lucide-react": "^0.554.0",
    "next": "15.5.19",
    "next-auth": "^4.24.14",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
